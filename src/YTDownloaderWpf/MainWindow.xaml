<Window x:Class="YtDownloaderWpf.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="YT Downloader"
        Height="720"
        Width="1050"
        MinHeight="620"
        MinWidth="900"
        Background="#111827">

    <Grid Margin="20">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="1*"/>
            <ColumnDefinition Width="20"/>
            <ColumnDefinition Width="2*"/>
        </Grid.ColumnDefinitions>

        <!-- LEWA KOLUMNA -->
        <ScrollViewer Grid.Column="0"
                      VerticalScrollBarVisibility="Auto">

            <StackPanel>

                <Border Style="{StaticResource CardStyle}">
                    <StackPanel>
                        <TextBlock Text="YouTube URL"
                                   Style="{StaticResource SectionTitleStyle}"/>

                        <TextBox Style="{StaticResource InputTextStyle}"
                            Text="{Binding Url, UpdateSourceTrigger=PropertyChanged}"/>

                        <Button Content="Pobierz informacje"
                                Style="{StaticResource PrimaryButton}"
                                Command="{Binding LoadVideoInfoCommand}"/>
                    </StackPanel>
                </Border>

                <Border Style="{StaticResource CardStyle}">
                    <StackPanel>
                        <TextBlock Text="Opcje pobierania"
                                   Style="{StaticResource SectionTitleStyle}"/>

                        <TextBlock Text="Tryb pobierania" Style="{StaticResource OptionTitleStyle}"/>
                        <ComboBox ItemsSource="{Binding DownloadModes}"
                                  SelectedItem="{Binding SelectedDownloadMode}"/>

                        <TextBlock Text="Format wyjściowy" Style="{StaticResource OptionTitleStyle}"/>
                        <ComboBox ItemsSource="{Binding OutputFormats}"
                                  SelectedItem="{Binding SelectedOutputFormat}"/>

                        <TextBlock Text="Jakość" Style="{StaticResource OptionTitleStyle}"/>
                        <ComboBox ItemsSource="{Binding Qualities}"
                                  SelectedItem="{Binding SelectedQuality}"/>
                    </StackPanel>
                </Border>

                <Border Style="{StaticResource CardStyle}">
                    <StackPanel>
                        <TextBlock Text="Folder zapisu"
                                   Style="{StaticResource SectionTitleStyle}"/>

                        <TextBox Style="{StaticResource InputTextStyle}"
                            Text="{Binding DownloadFolder}"
                                 IsReadOnly="True"/>

                        <Button Content="Wybierz folder"
                                Style="{StaticResource PrimaryButton}"
                                Command="{Binding SelectDownloadFolderCommand}"/>
                    </StackPanel>
                </Border>

                <Border Style="{StaticResource CardStyle}">
                    <StackPanel>
                        <Button Content="Pobierz"
                                Style="{StaticResource PrimaryButton}"
                                Command="{Binding DownloadCommand}"
                                FontWeight="Bold"/>


                        <Button Content="Anuluj" Margin="0,8,0,0"
                                Style="{StaticResource RedButton}"
                                Command="{Binding CancelDownloadCommand}"/>
                    </StackPanel>
                </Border>

            </StackPanel>
        </ScrollViewer>

        <!-- PRAWA KOLUMNA -->
        <Grid Grid.Column="2">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <Border Grid.Row="0"
                    Style="{StaticResource CardStyle}">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="320"/>
                        <ColumnDefinition Width="20"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>

                    <Border Height="180"
                            CornerRadius="12"
                            ClipToBounds="True"
                            Background="#374151">

                        <Image Source="{Binding ThumbnailUrl}"
                               Stretch="UniformToFill"/>
                    </Border>

                    <StackPanel Grid.Column="2"
                                VerticalAlignment="Center">

                        <TextBlock Text="{Binding VideoTitle}"
                                   FontSize="22"
                                   FontWeight="Bold"
                                   TextWrapping="Wrap"
                                   Foreground="SlateGray"/>

                        <TextBlock Text="{Binding Uploader}"
                                   Margin="0,10,0,0"
                                   FontSize="14"
                                   Foreground="#9CA3AF"/>
                    </StackPanel>
                </Grid>
            </Border>

            <Border Grid.Row="1"
                    Style="{StaticResource CardStyle}">
                <StackPanel>
                    <TextBlock Text="Postęp"
                               Style="{StaticResource SectionTitleStyle}"/>

                    <ProgressBar Value="{Binding Progress}"
                                 Height="22"
                                 Minimum="0"
                                 Maximum="100"/>

                    <TextBlock Text="{Binding StatusText}"
                               Margin="0,10,0,0"
                               FontWeight="SemiBold"
                               Foreground="SlateGray"/>
                </StackPanel>
            </Border>

            <Border Grid.Row="2"
                    Style="{StaticResource CardStyle}">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

                    <TextBlock Text="Log"
                               Style="{StaticResource SectionTitleStyle}"/>

                    <TextBox Grid.Row="1"
                             Text="{Binding LogText}"
                             IsReadOnly="True"
                             TextWrapping="Wrap"
                             VerticalScrollBarVisibility="Auto"
                             AcceptsReturn="True"
                             Height="Auto"/>

                </Grid>
            </Border>

        </Grid>
    </Grid>
</Window>